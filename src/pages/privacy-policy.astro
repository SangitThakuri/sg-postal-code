---
import BaseLayout from '../layouts/BaseLayout.astro';
const updated = 'June 22, 2025';
---

<BaseLayout
  title="Privacy Policy | GoldPriceNepal.online"
  description="Privacy policy for GoldPriceNepal.online. Learn how we collect, use, and protect your data."
  canonical="https://www.goldpricenepal.online/privacy-policy"
>
  <div class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Privacy Policy</h1>
      <p class="text-gray-500 text-sm mb-8">Last updated: {updated}</p>

      <div class="prose prose-gray max-w-none space-y-6 text-gray-600">
        <section>
          <h2 class="text-xl font-bold text-gray-900">1. Information We Collect</h2>
          <p>
            GoldPriceNepal.online is a static informational website. We do not require users to
            create accounts or submit personal information to use our core features. We may collect:
          </p>
          <ul class="list-disc list-inside space-y-1 mt-2">
            <li>Anonymous usage data via web analytics (page views, device type, country)</li>
            <li>Email addresses if you voluntarily subscribe to our price alert newsletter</li>
          </ul>
        </section>

        <section>
          <h2 class="text-xl font-bold text-gray-900">2. How We Use Your Information</h2>
          <ul class="list-disc list-inside space-y-1">
            <li>To send daily gold price alerts (newsletter subscribers only)</li>
            <li>To analyze and improve website performance</li>
            <li>To comply with legal obligations</li>
          </ul>
        </section>

        <section>
          <h2 class="text-xl font-bold text-gray-900">3. Cookies and Tracking</h2>
          <p>
            We may use cookies for analytics purposes (e.g., Google Analytics). These cookies do
            not identify you personally. You can disable cookies in your browser settings.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-gray-900">4. Third-Party Services</h2>
          <p>
            We use Google AdSense to display advertisements. Google may use cookies to show
            personalized ads based on your browsing history. Please refer to
            <a href="https://policies.google.com/privacy" target="_blank" rel="noopener" class="text-yellow-600 hover:underline">
              Google's Privacy Policy
            </a> for details.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-gray-900">5. Data Retention</h2>
          <p>
            Newsletter email addresses are retained until you unsubscribe. Analytics data is
            retained for a maximum of 26 months.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-gray-900">6. Your Rights</h2>
          <p>
            You have the right to access, correct, or delete your personal data. To make a
            request, contact us at
            <a href="mailto:info@goldpricenepal.online" class="text-yellow-600 hover:underline">
              info@goldpricenepal.online
            </a>.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-gray-900">7. Changes to This Policy</h2>
          <p>
            We may update this privacy policy from time to time. We will post the revised date
            at the top of this page. Continued use of the site constitutes acceptance.
          </p>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>

---
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-white mb-3">
          <span class="text-2xl">🥇</span>
          <span>GoldPrice<span class="text-yellow-400">Nepal</span><span class="text-yellow-400 text-sm">.online</span></span>
        </a>
        <p class="text-sm text-gray-400 max-w-xs">
          Your trusted source for live gold and silver prices in Nepal. Updated daily from FENEGOSIDA.
        </p>
        <p class="mt-3 text-xs text-gray-500">
          Rates sourced from FENEGOSIDA (Federation of Nepal Gold &amp; Silver Dealers Associations).
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold mb-3">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-yellow-400 transition-colors">Home</a></li>
          <li><a href="/gold-price-nepal" class="hover:text-yellow-400 transition-colors">Today's Gold Price</a></li>
          <li><a href="/gold-calculator" class="hover:text-yellow-400 transition-colors">Gold Calculator</a></li>
          <li><a href="/gold-news" class="hover:text-yellow-400 transition-colors">Gold News</a></li>
        </ul>
      </div>

      <!-- Info -->
      <div>
        <h3 class="text-white font-semibold mb-3">Information</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="hover:text-yellow-400 transition-colors">About Us</a></li>
          <li><a href="/privacy-policy" class="hover:text-yellow-400 transition-colors">Privacy Policy</a></li>
          <li>
            <a
              href="https://fenegosida.org"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-yellow-400 transition-colors"
            >FENEGOSIDA</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-8 pt-6 flex flex-col md:flex-row justify-between items-center text-xs text-gray-500">
      <p>&copy; {year} GoldPriceNepal.online. All rights reserved.</p>
      <p class="mt-2 md:mt-0">Disclaimer: Prices are for informational purposes only. Not financial advice.</p>
    </div>
  </div>
</footer>

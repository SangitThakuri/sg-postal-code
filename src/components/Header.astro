---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/gold-price-nepal', label: 'Gold Price' },
  { href: '/gold-calculator', label: 'Calculator' },
  { href: '/gold-news', label: 'News' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-gray-900 text-white shadow-lg sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 font-bold text-xl">
        <span class="text-2xl">🥇</span>
        <span>
          GoldPrice<span class="text-yellow-400">Nepal</span>
          <span class="text-yellow-400 text-sm font-normal">.online</span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors hover:text-yellow-400 ${
              currentPath === link.href ? 'text-yellow-400' : 'text-gray-300'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Live badge -->
      <div class="hidden md:flex items-center gap-2 bg-green-900/50 border border-green-700 rounded-full px-3 py-1">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        <span class="text-xs text-green-400 font-medium">Live Rates</span>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-md text-gray-400 hover:text-white hover:bg-gray-700"
        aria-label="Toggle menu"
      >
        <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="md:hidden hidden pb-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`block px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700 hover:text-white ${
            currentPath === link.href ? 'bg-gray-700 text-yellow-400' : 'text-gray-300'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const open = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', open);
    menuIcon?.classList.toggle('hidden', !open);
    closeIcon?.classList.toggle('hidden', open);
  });
</script>
